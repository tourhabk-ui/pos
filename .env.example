# ===========================================
# KamchatourHub — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# Required vars are marked with [REQUIRED].
# All others are optional with sensible defaults.

# ── Core / Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# ── Database (PostgreSQL) [REQUIRED] ────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_SSL=false
DATABASE_MAX_CONNECTIONS=20
DATABASE_CONNECTION_TIMEOUT=2000
DATABASE_IDLE_TIMEOUT=30000

# ── Auth (JWT) [REQUIRED] ──────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Timeweb Cloud ──────────────────────────────────────────────────
TIMEWEB_TOKEN=your-timeweb-api-token
TIMEWEB_TOKEN1=
TIMEWEB_API_TOKEN=your-timeweb-api-token
TIMEWEB_AI_AGENT_ID=your-timeweb-ai-agent-id
TIMEWEB_AI_KB_ID=

# ── AI Providers (waterfall: Timeweb -> OpenRouter -> DeepSeek -> Minimax -> xAI -> Anthropic)
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MANAGEMENT_KEY=     # Needed for balance check: OpenRouter → Settings → Management Keys
ANTHROPIC_API_KEY=
AI_MAX_TOKENS=800
AI_DAILY_BUDGET_USD=10.0

# ── Telegram: @KuzmichKam_bot (public) ─────────────────────────────
# Webhook: POST /api/telegram/webhook
# Setup: POST /api/telegram/setup-webhook (one-time)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=                        # Admin group chat ID (receives leads + booking alerts)
TELEGRAM_FISHING_CHAT_ID=               # Operator auth chat ID (inline booking buttons)
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret
TELEGRAM_CHANNEL_ID=                     # Public channel ID (Kuzmich autoposts)
TELEGRAM_LEADS_CHAT_ID=                  # Diagnostic only (can be same as TELEGRAM_CHAT_ID)

# ── Telegram: @tourhab_bot (owner-only admin) ───────────────────────
# Webhook: POST /api/telegram/admin
# Setup: scripts/setup-telegram-admin-bot.sh (one-time)
TELEGRAM_ADMIN_BOT_TOKEN=your-admin-bot-token
TELEGRAM_OWNER_ID=833478813              # Your numeric Telegram user ID
TELEGRAM_ADMIN_CHAT_ID=                  # SOS alert destination (can be same as TELEGRAM_CHAT_ID)

# ── Telegram: Login Widget ──────────────────────────────────────────
# The public @username of the bot (without @)
# REQUIRED: run /setdomain → tourhab.ru in BotFather first
# Widget only renders on /auth/login when this var is set
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=KuzmichKam_bot

# ── MAX Messenger: Bot Kuzmich (ID4101147649) ───────────────────────
# Webhook: POST /api/max/kuzmich
# Polling: GET /api/max/kuzmich (for cron/dev)
# Channel: max.ru/id4101147549_biz
MAX_BOT_TOKEN=your-max-bot-token
MAX_CHANNEL_ID=-72338356401519
MAX_CHANNEL_LINK=https://max.ru/id4101147649_biz
TELEGRAM_CHANNEL_LINK=https://t.me/kamchatka_real

# ── Email (SMTP) ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=
EMAIL_FROM=noreply@kamchatour.ru

# ── SMS ────────────────────────────────────────────────────────────
SMS_RU_API_KEY=

# ── Payments ───────────────────────────────────────────────────────
# CloudPayments
CLOUDPAYMENTS_API_SECRET=your-cloudpayments-secret
NEXT_PUBLIC_CLOUDPAYMENTS_PUBLIC_ID=your-cloudpayments-public-id

# Yandex Payment
YANDEX_PAYMENT_SHOP_ID=
YANDEX_PAYMENT_SECRET_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Platform commission (0.0 to 1.0)
PLATFORM_COMMISSION_RATE=0.15

# ── Maps / Geocoding ──────────────────────────────────────────────
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=your-yandex-maps-js-api-key
YANDEX_MAPS_API_KEY=your-yandex-maps-server-api-key

# ── Weather APIs ───────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=
WEATHERAPI_KEY=
YANDEX_WEATHER_API_KEY=

# ── File Storage / S3 (Timeweb S3) ────────────────────────────────
FILE_MAX_SIZE=10485760
FILE_UPLOAD_PATH=/uploads
CDN_URL=
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_ENDPOINT=https://s3.twcstorage.ru
S3_BUCKET=your-s3-bucket-name
S3_REGION=ru-1

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=
REDIS_PASSWORD=
REDIS_DB=0

# Upstash Redis (for rate limiting in Edge middleware)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Partners ───────────────────────────────────────────────────────
KAMCHATKA_FISHING_API_KEY=
KAMCHATKA_FISHING_API_SECRET=

# ── Safety (MCHS integration) ─────────────────────────────────────
MCHS_API_URL=
MCHS_API_TOKEN=

# ── External Services ─────────────────────────────────────────────
# CRON_SECRET protects /api/cron/* endpoints — set in cron-job.org as ?secret=<CRON_SECRET>
CRON_SECRET=your-long-random-cron-secret
CREWAI_API_URL=http://localhost:8001
WEBHOOK_SECRET=
KNOWLEDGE_BASE_SOURCE_URLS=
MARKDOWN_NEW_ENDPOINT=

# ── Monitoring ─────────────────────────────────────────────────────
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# ── CORS ───────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Analytics / SEO ────────────────────────────────────────────────
GOOGLE_ANALYTICS_ID=
YANDEX_METRIKA_ID=
GOOGLE_SITE_VERIFICATION=
YANDEX_VERIFICATION=

# ── Development Flags ─────────────────────────────────────────────
MOCK_DATA=false
VERBOSE_LOGGING=false
